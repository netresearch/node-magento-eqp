# direnv configuration — automatically runs when entering this directory.
# Requires direnv: https://direnv.net/ + `direnv allow` to activate.

# Install dependencies and set up git hooks if needed
if [ -f package.json ]; then
	if [ ! -d node_modules ]; then
		echo "Installing dependencies..."
		bun install
	fi

	# Ensure husky git hooks are configured
	if [ "$(git config core.hooksPath 2>/dev/null)" != ".husky/_" ]; then
		echo "Setting up git hooks..."
		bunx husky
	fi
fi
